# API base URL (no trailing slash).
#
# — On a REAL DEVICE (Expo Go on iPhone/Android): use your computer's LAN IP so the phone
#   can reach the server. Example: http://192.168.5.6:4004/api (replace with your PC IP).
#   Phone and PC must be on the same Wi‑Fi. Server must be running: cd server && npm run dev
#
# — In browser (npm run web): use http://localhost:4004/api if the server runs on the same machine.
#
# — Production: use your EC2/public URL, e.g. http://54.164.243.18/api
EXPO_PUBLIC_API_URL=http://192.168.5.6:4004/api
